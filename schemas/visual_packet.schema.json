{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/vision-harness-skill/schemas/visual_packet.schema.json",
  "title": "Vision Harness Visual Packet",
  "type": "object",
  "required": ["version", "source", "image_properties", "visual_features", "layout_regions", "ocr_blocks", "image_type_hypotheses", "routing", "uncertainties"],
  "properties": {
    "version": {"type": "string"},
    "mode": {"type": "string"},
    "task": {"type": "string"},
    "source": {
      "type": "object",
      "required": ["input_type", "filename"],
      "properties": {
        "input_type": {"type": "string"},
        "filename": {"type": "string"},
        "sha256": {"type": "string"}
      }
    },
    "image_properties": {
      "type": "object",
      "required": ["width", "height", "aspect_ratio", "orientation"],
      "properties": {
        "width": {"type": "integer"},
        "height": {"type": "integer"},
        "aspect_ratio": {"type": "number"},
        "orientation": {"type": "string"},
        "megapixels": {"type": "number"}
      }
    },
    "visual_features": {"type": "object"},
    "layout_regions": {"type": "array", "items": {"$ref": "#/$defs/region"}},
    "ocr_blocks": {"type": "array", "items": {"$ref": "#/$defs/ocr_block"}},
    "text_line_groups": {"type": "array", "items": {"$ref": "#/$defs/text_line_group"}},
    "evidence_quotes": {"type": "array", "items": {"$ref": "#/$defs/evidence_quote"}},
    "spatial_layout_analysis": {"type": "object"},
    "structure_candidates": {"type": "object"},
    "image_type_hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "confidence", "evidence"],
        "properties": {
          "type": {"type": "string"},
          "confidence": {"type": "string"},
          "evidence": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "routing": {
      "type": "object",
      "required": ["recommended_template", "reason"],
      "properties": {
        "recommended_template": {"type": "string"},
        "reason": {"type": "string"}
      }
    },
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "agent_notes": {"type": "string"}
  },
  "$defs": {
    "bbox": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "integer"}},
    "region": {
      "type": "object",
      "required": ["id", "type_hint", "bbox"],
      "properties": {
        "id": {"type": "string"},
        "type_hint": {"type": "string"},
        "bbox": {"$ref": "#/$defs/bbox"},
        "visual_weight": {"type": "string"},
        "contains_text_ids": {"type": "array", "items": {"type": "string"}},
        "notes": {"type": "string"}
      }
    },
    "ocr_block": {
      "type": "object",
      "required": ["id", "text", "bbox", "confidence"],
      "properties": {
        "id": {"type": "string"},
        "text": {"type": "string"},
        "normalized_text": {"type": "string"},
        "bbox": {"$ref": "#/$defs/bbox"},
        "confidence": {"type": "number"},
        "region_id": {"type": "string"}
      }
    },
    "text_line_group": {
      "type": "object",
      "required": ["id", "text", "bbox", "text_ids"],
      "properties": {
        "id": {"type": "string"},
        "text": {"type": "string"},
        "bbox": {"$ref": "#/$defs/bbox"},
        "text_ids": {"type": "array", "items": {"type": "string"}},
        "region_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence_quote": {
      "type": "object",
      "required": ["id", "raw_text", "normalized_text"],
      "properties": {
        "id": {"type": "string"},
        "region_id": {"type": "string"},
        "raw_text": {"type": "string"},
        "normalized_text": {"type": "string"},
        "bbox": {"$ref": "#/$defs/bbox"},
        "confidence": {"type": ["number", "null"]}
      }
    }
  }
}
